{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix correlation-dashboard install --no-audit --no-fund",
  "buildCommand": "npm --prefix correlation-dashboard run build",
  "outputDirectory": "correlation-dashboard/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
